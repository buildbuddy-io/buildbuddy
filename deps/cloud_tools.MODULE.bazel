# ─────────────────────────────────────────────────────────────────────────────
# AWS CLI v2.34.45
# ─────────────────────────────────────────────────────────────────────────────
#
# AWS distributes CLI v2 as a zip containing aws/ with a bundled CPython.
# The build_file exposes the whole tree so the sh_binary wrapper can exec
# aws/dist/aws directly.  No system Python needed.
#
# macOS: AWS only ships a .pkg for macOS, so only Linux variants are listed.
# Add darwin support if macOS dev usage is required.

_AWS_BUILD_FILE = """
package(default_visibility = ["//visibility:public"])
filegroup(
    name = "aws",
    srcs = glob(["aws/**"], allow_empty = False),
)
"""

http_archive(
    name = "aws_cli_linux_x86_64",
    build_file_content = _AWS_BUILD_FILE,
    sha256 = "2b382fd5c1e8d73f6aaca18e5850758fb9f70a20af9c17deb3078df0dd4af095",
    urls = ["https://awscli.amazonaws.com/awscli-exe-linux-x86_64-2.34.45.zip"],
)

http_archive(
    name = "aws_cli_linux_aarch64",
    build_file_content = _AWS_BUILD_FILE,
    sha256 = "bf29e06a06fb9bac2a3803931e6618a9f7c9f4c6632ec3b587184850b8f03433",
    urls = ["https://awscli.amazonaws.com/awscli-exe-linux-aarch64-2.34.45.zip"],
)
