# Cloud tool binaries: gcloud SDK, gke-gcloud-auth-plugin, kubectl, aws CLI.
# Exposed as Bazel targets under //tools/cloud_tools.
#
# To update versions:
#   gcloud:   https://cloud.google.com/sdk/docs/release-notes
#             Update GCLOUD_SDK_VERSION and re-fetch sha256 for each platform:
#             curl -sL https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-sdk-<VER>-<PLAT>.tar.gz | sha256sum
#
#   kubectl:  https://dl.k8s.io/release/stable.txt
#             sha256 at https://dl.k8s.io/release/<VER>/bin/<os>/<arch>/kubectl.sha256
#
#   aws CLI:  https://github.com/aws/aws-cli/tags  (pick latest 2.x)
#             curl -sL https://awscli.amazonaws.com/awscli-exe-linux-x86_64-<VER>.zip | sha256sum

# http_archive and http_file are declared in the root MODULE.bazel and
# available in scope here via include().

# ─────────────────────────────────────────────────────────────────────────────
# gcloud SDK 568.0.0
# ─────────────────────────────────────────────────────────────────────────────
#
# The gcloud entry-point is a shell script that bootstraps a bundled Python
# runtime and sets CLOUDSDK_ROOT_DIR.  We expose ALL files in the archive as a
# single "sdk" filegroup so the sh_binary runfiles tree contains the full SDK.
#
# Only one archive is downloaded per host platform (Bazel selects via the
# alias in //tools/cloud_tools:gcloud, but the http_archives themselves are
# always declared -- they are only fetched if a target that uses them is built).

_GCLOUD_BUILD_FILE = """
package(default_visibility = ["//visibility:public"])
filegroup(
    name = "sdk",
    srcs = glob(["google-cloud-sdk/**"], allow_empty = False),
)
"""

http_archive(
    name = "gcloud_sdk_linux_x86_64",
    build_file_content = _GCLOUD_BUILD_FILE,
    sha256 = "ef53b350c5da53b7e92d90ab6f65a85c712686858b839e44e6529d5883fd575c",
    urls = ["https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-sdk-568.0.0-linux-x86_64.tar.gz"],
)

http_archive(
    name = "gcloud_sdk_linux_arm",
    build_file_content = _GCLOUD_BUILD_FILE,
    sha256 = "119f00184832664b0acfe758395a6b12c57f0f7dd7ec070cdfb193b7b5142b87",
    urls = ["https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-sdk-568.0.0-linux-arm.tar.gz"],
)

http_archive(
    name = "gcloud_sdk_darwin_x86_64",
    build_file_content = _GCLOUD_BUILD_FILE,
    sha256 = "60396fc644ab277a10f61bd83720f32f9b89ce1dcc2c6653dede132236b5a978",
    urls = ["https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-sdk-568.0.0-darwin-x86_64.tar.gz"],
)

http_archive(
    name = "gcloud_sdk_darwin_arm",
    build_file_content = _GCLOUD_BUILD_FILE,
    sha256 = "1760391dc09e1a16c62b1b6760bbdebf49385fb9870f240a76545ae95ba1b2ec",
    urls = ["https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-sdk-568.0.0-darwin-arm.tar.gz"],
)

# ─────────────────────────────────────────────────────────────────────────────
# gke-gcloud-auth-plugin 0.5.14  (from gcloud component channel)
# ─────────────────────────────────────────────────────────────────────────────
#
# Each archive contains a single executable: bin/gke-gcloud-auth-plugin.
# The build_file exposes it as a "plugin" executable target.
#
# sha256 values are the "checksum" field from the gcloud component manifest:
#   https://dl.google.com/dl/cloudsdk/channels/rapid/components-2.json

_GKE_PLUGIN_BUILD_FILE = """
package(default_visibility = ["//visibility:public"])
exports_files(["bin/gke-gcloud-auth-plugin"])
filegroup(
    name = "plugin",
    srcs = ["bin/gke-gcloud-auth-plugin"],
)
"""

http_archive(
    name = "gke_auth_plugin_linux_x86_64",
    build_file_content = _GKE_PLUGIN_BUILD_FILE,
